# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Email Notification Configurations (SMTP)
# SENDER_EMAIL: Correo electrónico emisor (por ejemplo, alertas@o3energy.mx)
# SENDER_PASSWORD: Contraseña o token de aplicación para el remitente
# SALES_EMAIL: Correo electrónico del equipo de ventas receptor (por ejemplo, ventas@o3energy.mx)
# SMTP_SERVER: Servidor SMTP (por defecto smtp.gmail.com)
# SMTP_PORT: Puerto SMTP (por defecto 587)
SENDER_EMAIL=
SENDER_PASSWORD=
SALES_EMAIL=
SMTP_SERVER=
SMTP_PORT=
